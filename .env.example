DJANGO_SECRET_KEY=change-me-dev-only-not-for-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Postgres credentials — used by Docker Compose to initialise the local container.
# Must match the credentials embedded in DATABASE_URL below.
POSTGRES_DB=hwdb
POSTGRES_USER=hwdb_admin
POSTGRES_PASSWORD=change-me

# Database URL for dj-database-url
DATABASE_URL=postgres://hwdb_admin:change-me@localhost:5433/hwdb
DATABASE_SSL_REQUIRE=false

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Django superuser created automatically on first deploy (start.sh).
# Set in the deployment environment (e.g. Railway dashboard); do not commit real values.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me